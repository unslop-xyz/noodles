# LLM Provider Configuration
# --------------------------

# Provider to use: anthropic (default), openai, gemini, groq, or huggingface
# LLM_PROVIDER=anthropic

# Model name (optional - uses provider-specific default if not set)
# Anthropic: claude-haiku-4-5-20251001
# OpenAI: gpt-4o-mini
# Gemini: gemini-2.0-flash
# Groq: llama-3.3-70b-versatile
# HuggingFace: moonshotai/Kimi-K2-Instruct
# LLM_MODEL=claude-haiku-4-5-20251001

# Base URL for OpenAI-compatible endpoints (optional)
# Use this for Ollama, vLLM, LMStudio, etc. with the openai provider
# LLM_BASE_URL=http://localhost:8080/v1

# API Keys
# --------

# Anthropic API key (required when using LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API key (required when using LLM_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-api-key-here

# Google API key (required when using LLM_PROVIDER=gemini)
# GOOGLE_API_KEY=your-google-api-key-here

# Groq API key (required when using LLM_PROVIDER=groq)
# Get your key at: https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-groq-api-key-here

# HuggingFace token (required when using LLM_PROVIDER=huggingface)
# Get your token at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your-huggingface-token-here
